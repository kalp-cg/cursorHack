# VedyaAI Environment Configuration
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://vedya:vedyapass@localhost:5433/vedyaai

# ── LLM (optional — system works without it) ──────
OPENAI_API_KEY=sk-...

# Set to "false" to disable LLM (M3 gate mode — ranker-only)
LLM_ENABLED=false

# ── Auth ──────────────────────────────────────────
JWT_SECRET=vedya-dev-secret-change-me-in-production
JWT_EXPIRE_HOURS=72

# ── App config ────────────────────────────────────
CORPUS_VERSION=1.0.0

# ── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

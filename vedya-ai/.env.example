# VedyaAI Environment Configuration
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────
# Neon (recommended for deploy) or local Docker Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# Local: postgresql://vedya:vedyapass@localhost:5433/vedyaai

# ── LLM (optional — system works without it) ──────
OPENAI_API_KEY=sk-...

# Set to "false" to disable LLM (M3 gate mode — ranker-only)
LLM_ENABLED=false

# ── Auth ──────────────────────────────────────────
JWT_SECRET=vedya-dev-secret-change-me-in-production
JWT_EXPIRE_HOURS=72

# ── App config ────────────────────────────────────
CORPUS_VERSION=1.0.0

# ── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Deployment ────────────────────────────────────
# Comma-separated deployed frontend URLs for CORS, e.g.
FRONTEND_ORIGINS=https://cursor-hack-green.vercel.app,https://cursor-hack-gamma.vercel.app
# Uvicorn workers in the Docker image (default 2)
WEB_CONCURRENCY=2

# ── Free translation (no paid key) ────────────────
# Chain: MyMemory → LibreTranslate → Lingva (all free, no API key).
# Optional: point at your own LibreTranslate instance.
# LIBRETRANSLATE_URL=http://localhost:5000

# ── ElevenLabs voice (optional) ───────────────────
# Without a key, /voice/* returns 503 and UI hides mic / shows Voice off.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v2

# ── SMTP (Gmail App Password for forgot-password) ─
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Set true only for local debugging (returns reset_code in API)
SMTP_DEV_ECHO=false
